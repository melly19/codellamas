{
  "name": "codellamas",
  "version": "1.0.0",
  "description": "VSCode extension with frontend testing",
  "main": "index.js",
  "scripts": {
    "test": "jest",
    "test:frontend": "jest frontend"
  },
  "dependencies": {
    "dotenv": "^17.3.1"
  },
  "devDependencies": {
    "@types/jest": "^29.0.0",
    "@types/node": "^25.5.2",
    "jest": "^29.0.0",
    "jest-environment-jsdom": "^29.0.0",
    "ts-jest": "^29.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "jsdom",
    "testMatch": ["**/frontend/src/test/**/frontend.test.ts"],
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.test.json"
        }
      ]
    }
  }
}