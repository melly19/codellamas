{
  "name": "codellamas",
  "displayName": "codellamas",
  "publisher": "MichaelSuteja",
  "description": "Java Spring Boot Refactoring Exercise Generator",
  "version": "1.3.0",
  "engines": {
    "vscode": "^1.108.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:codellamas_activityView",
    "onCommand:code-llamas.helloWorld"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "code-llamas.helloWorld",
        "title": "Hello World"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codellamas_activity",
          "title": "Codellamas",
          "icon": "media/code-llamas.png"
        }
      ]
    },
    "views": {
      "codellamas_activity": [
        {
          "id": "codellamas_activityView",
          "name": "Codellamas",
          "type": "webview"
        }
      ]
    },
    "configuration": {
      "title": "Java Spring Boot Exercise Generator",
      "properties": {
        "javaExerciseGenerator.backendBaseUrl": {
          "type": "string",
          "default": "http://127.0.0.1:8000",
          "description": "Base URL of the internal backend API running on the GPU cluster or via SSH tunnel."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.17",
    "@types/unzipper": "^0.10.11",
    "@types/vscode": "^1.108.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.52.0"
  },
  "dependencies": {
    "marked": "^17.0.6",
    "treeselectjs": "^0.14.2",
    "unzipper": "^0.12.3"
  }
}
